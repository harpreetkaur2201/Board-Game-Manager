@model List<Board_Game_Manager.Models.Game>

<h1 class="mb-3">Game</h1>

@if (User.IsInRole("Admin") || User.IsInRole("GM"))
{
    <a asp-action="Create" class="btn btn-success mb-3">Create New Game</a>
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No games available</div>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Description</th>
                <th>Duration</th>
                <th>Players</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var g in Model)
            {
                <tr>
                    <td>@g.GameID</td>
                    <td>@g.Name</td>
                    <td>@g.Description</td>
                    <td>@g.AvgDuration</td>
                    <td>@g.MinPlayerCount - @g.MaxPlayerCount</td>
                    <td>
                        <div class="d-flex gap-2 flex-wrap">
                            <a asp-action="Details" asp-route-id="@g.GameID" class="btn btn-sm btn-outline-secondary">Details</a>

                            @if (User.IsInRole("Admin") || User.IsInRole("GM"))
                            {
                                <a asp-action="Edit" asp-route-id="@g.GameID" class="btn btn-sm btn-outline-primary">Edit</a>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Delete" asp-route-id="@g.GameID" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}