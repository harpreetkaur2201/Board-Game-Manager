@model Board_Game_Manager.Models.Tournament

<h2>Tournament Details</h2>

<div class="card p-4 shadow-sm">
    <table class="table table-bordered">
        <tbody>
            <tr>
                <th style="width: 200px;">Tournament ID</th>
                <td>@Model.TournamentID</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>@Model.Name</td>
            </tr>
            <tr>
                <th>Game</th>
                <td>@Model.Game?.Name</td>
            </tr>
            <tr>
                <th>Start Date</th>
                <td>@Model.StartDate.ToString("yyyy-MM-dd")</td>
            </tr>
            <tr>
                <th>End Date</th>
                <td>@Model.EndDate.ToString("yyyy-MM-dd")</td>
            </tr>
            <tr>
                <th>Location</th>
                <td>@Model.Location</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>@Model.Description</td>
            </tr>
        </tbody>
    </table>

    <div class="d-grid gap-2 mt-3" style="max-width: 220px;">
        @if (User.IsInRole("Admin") || User.IsInRole("GM"))
        {
            <a asp-action="Edit" asp-route-id="@Model.TournamentID" class="btn btn-primary">Edit</a>
        }
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>