@model Board_Game_Manager.Models.Game

<h2>Game Details</h2>

<div class="card p-4 shadow-sm">
    <table class="table table-bordered">
        <tbody>
            <tr>
                <th style="width: 200px;">Game ID</th>
                <td>@Model.GameID</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>@Model.Name</td>
            </tr>
            <tr>
                <th>Image URL</th>
                <td>@Model.URL</td>
            </tr>
            <tr>
                <th>Game Description</th>
                <td>@Model.Description</td>
            </tr>
            <tr>
                <th>Avg Game Duration</th>
                <td>@Model.AvgDuration</td>
            </tr>
            <tr>
                <th>Min Player Count</th>
                <td>@Model.MinPlayerCount</td>
            </tr>
            <tr>
                <th>Max Player Count</th>
                <td>@Model.MaxPlayerCount</td>
            </tr>
            <tr>
                <th>Age Requirement</th>
                <td>@Model.AgeReq</td>
            </tr>
        </tbody>
    </table>

    <div class="mt-3">
        @if (User.IsInRole("Admin") || User.IsInRole("GM")) {
            <a asp-action="Edit" asp-route-id="@Model.GameID" class="btn btn-primary">Edit</a>
        }
        <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
    </div>
</div>