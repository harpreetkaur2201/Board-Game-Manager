@model Board_Game_Manager.Models.SessionParticipant

<h2 class="mb-4">Add Participant</h2>

@if (ViewBag.Session != null)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="mb-3">Session Information</h5>

            <p><strong>Session ID:</strong> @ViewBag.Session.SessionID</p>
            <p><strong>Game:</strong> @(ViewBag.Session.Game?.Name ?? "N/A")</p>
            <p><strong>Game Master:</strong> @(ViewBag.Session.GameMaster?.Player?.Name ?? "N/A")</p>
        </div>
    </div>
}

<form asp-action="CreateParticipant" method="post" class="card">
    <div class="card-body">

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="SessionID" />
        <input type="hidden" asp-for="JoinedAt" />

        <div class="mb-3">
            <label asp-for="PlayerID" class="form-label">Player</label>
            <select asp-for="PlayerID" asp-items="ViewBag.Players" class="form-select">
                <option value="">-- Select Player --</option>
            </select>
            <span asp-validation-for="PlayerID" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Score" class="form-label">Score</label>
            <input asp-for="Score" class="form-control" />
            <span asp-validation-for="Score" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Rank" class="form-label">Rank</label>
            <input asp-for="Rank" class="form-control" />
            <span asp-validation-for="Rank" class="text-danger"></span>
        </div>

        <div class="form-check mb-3">
            <input asp-for="IsWinner" class="form-check-input" />
            <label asp-for="IsWinner" class="form-check-label">Winner</label>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">Add Participant</button>
            <a asp-action="Details" asp-route-id="@Model.SessionID" class="btn btn-outline-secondary">Cancel</a>
        </div>

    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}