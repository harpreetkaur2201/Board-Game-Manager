@{
    ViewData["Title"] = "Home Page";
}

<div class="home-hero">
    <div class="home-overlay"></div>

    <div class="home-content text-center">
        <h1 class="home-title">Board Game Manager</h1>
        <p class="home-subtitle">
            Track games, manage sessions, and compete on the leaderboard
        </p>

        <div class="home-actions">
            <a asp-controller="Game" asp-action="Index" class="btn btn-primary">View Games</a>
            <a asp-controller="GameSession" asp-action="Index" class="btn btn-outline-secondary">Game Sessions</a>
            <a asp-controller="Leaderboard" asp-action="Index" class="btn btn-outline-secondary">Leaderboard</a>
        </div>
    </div>
</div>

<div class="home-grid">
    <div class="home-card">
        <h3>Games</h3>
        <p>Browse all available board games with details and player limits.</p>
    </div>

    <div class="home-card">
        <h3> Game Sessions</h3>
        <p>Track ongoing and past game sessions with full history.</p>
    </div>

    <div class="home-card">
        <h3> Leaderboard</h3>
        <p>See top players based on score, hours played, and GM contribution.</p>
    </div>
</div>