@model Board_Game_Manager.Models.Player

<h2>Player Details</h2>

<div class="card p-4 shadow-sm">
    <table class="table table-bordered">
        <tbody>
            <tr>
                <th style="width: 200px;">Player ID</th>
                <td>@Model.PlayerID</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>@Model.Name</td>
            </tr>
            <tr>
                <th>EMail</th>
                <td>@Model.Email</td>
            </tr>
            <tr>
                <th>Age</th>
                <td>@Model.Age</td>
            </tr>
            <tr>
                <th>Registered Time</th>
                <td>@Model.RegisteredAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
            </tr>
            <tr>
                <th>Total Hours Played</th>
                <td>@Model.TotalHours</td>
            </tr>
            <tr>
                <th>Game Master</th>
                <td>@(ViewBag.IsGameMaster ? "Yes" : "No")</td>
            </tr>
            @if (ViewBag.IsGameMaster) {
                <tr>
                    <th>GM Contribution Point</th>
                    <td>@ViewBag.GMContribution</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        @if (User.IsInRole("Admin") || User.IsInRole("GM")) {
            <a asp-action="Edit" asp-route-id="@Model.PlayerID" class="btn btn-primary">Edit</a>
        }
        <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
    </div>
</div>