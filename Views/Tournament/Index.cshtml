@model List<Board_Game_Manager.Models.Tournament>

<h1 class="mb-3">Tournaments</h1>

@if (User.IsInRole("Admin") || User.IsInRole("GM"))
{
    <a asp-action="Create" class="btn btn-success mb-3">
        Create New Tournament
    </a>
}

<div class="card shadow-sm">
    <div class="card-body p-0">

        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Game</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Description</th>
                    <th style="width: 220px;">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center p-3">
                            No tournaments available
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var t in Model)
                    {
                        <tr>
                            <td>@t.TournamentID</td>
                            <td>@t.Name</td>
                            <td>@t.Game?.Name</td>
                            <td>@t.StartDate.ToString("yyyy-MM-dd")</td>
                            <td>@t.EndDate.ToString("yyyy-MM-dd")</td>
                            <td style="max-width: 200px;">
                                @t.Description
                            </td>

                            <td>
                                <div class="d-flex gap-2 flex-wrap">

                                    <a asp-action="Details"
                                           asp-route-id="@t.TournamentID"
                                           class="btn btn-sm btn-outline-secondary">
                                        Details
                                    </a>

                                    @if (User.IsInRole("Admin") || User.IsInRole("GM"))
                                    {
                                        <a asp-action="Edit"
                                               asp-route-id="@t.TournamentID"
                                               class="btn btn-sm btn-outline-primary">
                                            Edit
                                        </a>
                                    }

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Delete"
                                               asp-route-id="@t.TournamentID"
                                               class="btn btn-sm btn-outline-danger">
                                            Delete
                                        </a>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

    </div>
</div>