@model Board_Game_Manager.Models.PlayerEditViewModel

@{
    ViewData["Title"] = "Edit Player";
}

<h2 class="mb-4">Edit Player</h2>

<form asp-action="Edit" method="post" class="card p-4 shadow-sm">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="PlayerID" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Age" class="form-label"></label>
        <input asp-for="Age" class="form-control" />
        <span asp-validation-for="Age" class="text-danger"></span>
    </div>
    <input type="hidden" asp-for="RegisteredAt" />
    <div class="mb-3">
        <label class="form-label">Registered Time</label>
        <input class="form-control" value="@Model.RegisteredAt.ToString("yyyy-MM-dd HH:mm:ss")" readonly />
    </div>
     <div class="form-check mb-3">
        <input asp-for="IsGameMaster" class="form-check-input" />
        <label asp-for="IsGameMaster" class="form-check-label">Assign as Game Master</label>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}