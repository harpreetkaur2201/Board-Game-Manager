@model List<Board_Game_Manager.Models.GameSession>

<h1 class="mb-3">Game Session</h1>

@if (User.IsInRole("Admin") || User.IsInRole("GM"))
{
    <a asp-controller="GameSession" asp-action="Create" class="btn btn-success mb-3">Create Game Session</a>
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No game sessions available</div>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Game Name</th>
                <th>Game Master Name</th>
                <th>Tournament Name</th>
                <th>Game Start Time</th>
                <th>Play Time Duration</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (GameSession g in Model)
            {
                <tr>
                    <td>@g.SessionID</td>
                    <td>@(g.Game?.Name ?? "N/A")</td>
                    <td>@(g.GameMaster?.Player?.Name ?? "N/A")</td>
                    <td>@(g.Tournament?.Name ?? "N/A")</td>
                    <td>@g.GameStartedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@g.PlayTimeMinutes</td>
                    <td>
                        <div class="d-flex gap-2 flex-wrap">
                            <a asp-action="Details" asp-route-id="@g.SessionID" class="btn btn-sm btn-outline-secondary">Details</a>

                            @if (User.IsInRole("Admin") || User.IsInRole("GM"))
                            {
                                <a asp-action="Edit" asp-route-id="@g.SessionID" class="btn btn-sm btn-outline-primary">Edit</a>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Delete" asp-route-id="@g.SessionID" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}