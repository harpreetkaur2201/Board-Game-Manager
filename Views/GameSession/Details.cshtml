@model Board_Game_Manager.Models.GameSession

<h2 class="mb-4">Game Session Details</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h4 class="card-title mb-3">Session Information</h4>

        <dl class="row">
            <dt class="col-sm-3">Session ID</dt>
            <dd class="col-sm-9">@Model.SessionID</dd>

            <dt class="col-sm-3">Game</dt>
            <dd class="col-sm-9">@(Model.Game?.Name ?? "N/A")</dd>

            <dt class="col-sm-3">Game Master</dt>
            <dd class="col-sm-9">@(Model.GameMaster?.Player?.Name ?? "N/A")</dd>

            <dt class="col-sm-3">Tournament</dt>
            <dd class="col-sm-9">@(Model.Tournament?.Name ?? "N/A")</dd>

            <dt class="col-sm-3">Average Duration</dt>
            <dd class="col-sm-9">@(Model.Game?.AvgDuration.ToString() ?? "N/A")</dd>

            <dt class="col-sm-3">Minimum Player Count</dt>
            <dd class="col-sm-9">@(Model.Game?.MinPlayerCount.ToString() ?? "N/A")</dd>

            <dt class="col-sm-3">Maximum Player Count</dt>
            <dd class="col-sm-9">@(Model.Game?.MaxPlayerCount.ToString() ?? "N/A")</dd>

            <dt class="col-sm-3">Start Time</dt>
            <dd class="col-sm-9">@Model.GameStartedAt.ToString("yyyy-MM-dd HH:mm")</dd>

            <dt class="col-sm-3">Play Time</dt>
            <dd class="col-sm-9">@Model.PlayTimeMinutes minutes</dd>
        </dl>

        <div class="mt-3">
            @if (User.IsInRole("Admin") || User.IsInRole("GM"))
            {
                <a asp-action="CreateParticipant" asp-route-id="@Model.SessionID" class="btn btn-success">
                    Add Participant
                </a>

                <a asp-action="Edit" asp-route-id="@Model.SessionID" class="btn btn-primary ms-2">
                    Edit Session
                </a>
            }

            <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h4 class="card-title mb-3">Participants</h4>

        <table class="table align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Player Name</th>
                    <th>Score</th>
                    <th>Rank</th>
                    <th>Winner</th>
                    <th>Joined At</th>

                    @if (User.IsInRole("Admin") || User.IsInRole("GM"))
                    {
                        <th style="width: 220px;">Actions</th>
                    }
                </tr>
            </thead>

            <tbody>
                @if (Model.SessionParticipants == null || !Model.SessionParticipants.Any())
                {
                    <tr>
                        <td colspan="@(User.IsInRole("Admin") || User.IsInRole("GM") ? 6 : 5)" class="text-center">
                            No participants added yet.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (SessionParticipant p in Model.SessionParticipants.OrderBy(sp => sp.Rank))
                    {
                        <tr>
                            <td>@(p.Player?.Name ?? "N/A")</td>
                            <td>@p.Score</td>
                            <td>@p.Rank</td>
                            <td>@(p.IsWinner ? "Yes" : "No")</td>
                            <td>@p.JoinedAt.ToString("yyyy-MM-dd HH:mm")</td>

                            @if (User.IsInRole("Admin") || User.IsInRole("GM"))
                            {
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-action="EditParticipant" asp-route-sessionId="@p.SessionID" asp-route-playerId="@p.PlayerID" class="btn btn-sm btn-primary">
                                            Edit
                                        </a>

                                        @if (User.IsInRole("Admin"))
                                        {
                                            <form asp-action="DeleteParticipant" method="post" class="m-0">
                                                <input type="hidden" name="sessionId" value="@p.SessionID" />
                                                <input type="hidden" name="playerId" value="@p.PlayerID" />
                                                <button type="submit"class="btn btn-sm btn-danger">Delete</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>